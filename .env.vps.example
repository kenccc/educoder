# Copy to .env on the VPS and replace every secret before first boot.

# ==== Public site ====
DOMAIN=educoder.cloud
ACME_EMAIL=admin@educoder.cloud

# ==== Django ====
DJANGO_SETTINGS_MODULE=educoder.settings.prod
DJANGO_SECRET_KEY=replace-with-output-of-openssl-rand-base64-48
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=educoder.cloud,www.educoder.cloud
DJANGO_CSRF_TRUSTED_ORIGINS=https://educoder.cloud,https://www.educoder.cloud

# Keep these conservative for FORPSI Basic Linux: 2 vCPU / 4 GB RAM.
WEB_CONCURRENCY=2
CELERY_CONCURRENCY=1
CELERY_TASK_ALWAYS_EAGER=0

# ==== Database ====
POSTGRES_DB=educoder
POSTGRES_USER=educoder
POSTGRES_PASSWORD=replace-with-strong-database-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ==== Redis ====
REDIS_URL=redis://redis:6379/0
CHANNEL_LAYER_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=django-db

# ==== Execution runner ====
EXECUTION_RUNNER_URL=http://execution-runner:8080
EXECUTION_RUNNER_TOKEN=replace-with-strong-runner-token
SANDBOX_IMAGE=educoder/sandbox-python:latest
SANDBOX_CPU_LIMIT=0.5
SANDBOX_MEMORY_LIMIT=128m
SANDBOX_TIMEOUT_SECONDS=5
SANDBOX_NETWORK=none

# ==== Email ====
# SMTP on ports 25/465/587 is available on a VPS if your provider/firewall allows it.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
