# ==== Django ====
DJANGO_SETTINGS_MODULE=educoder.settings.dev
DJANGO_SECRET_KEY=replace-me-with-strong-random-value
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,django-web
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8090,http://127.0.0.1:8090

# ==== Database ====
POSTGRES_DB=educoder
POSTGRES_USER=educoder
POSTGRES_PASSWORD=educoder
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Render provides DATABASE_URL automatically from the managed Postgres service.
# DATABASE_URL=postgresql://educoder:educoder@postgres:5432/educoder

# ==== Redis ====
REDIS_URL=redis://redis:6379/0
CHANNEL_LAYER_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3
# Free Render deploys use inline Celery because free background workers are unavailable.
CELERY_TASK_ALWAYS_EAGER=0

# ==== Execution runner ====
EXECUTION_RUNNER_URL=http://execution-runner:8080
EXECUTION_RUNNER_TOKEN=replace-with-shared-secret
SANDBOX_IMAGE=educoder/sandbox-python:latest
SANDBOX_CPU_LIMIT=0.5
SANDBOX_MEMORY_LIMIT=128m
SANDBOX_TIMEOUT_SECONDS=5
SANDBOX_NETWORK=none

# ==== Email (dev: console) ====
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
